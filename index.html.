<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FitWin</title>
<link rel="stylesheet" href="style.css">

</head>
<body>

<header>
💪 FitWin
<br><br>
<button onclick="mostrarLogin()">Iniciar sesión</button>
<button onclick="mostrarRegistro()">Registrarse</button>
</header>

<div class="card">
<h2>Tu cartera</h2>
<p id="saldo">0,00 €</p>

<h2>Flexiones</h2>
<p id="flexiones">0</p>

<button onclick="sumar()">+1 Flexión</button>
</div>

<div id="login" class="card" style="display:none;">
<h2>Iniciar sesión</h2>

<input type="text" placeholder="Usuario">

<input type="password" placeholder="Contraseña">

<button>Entrar</button>
</div>
<div id="registro" class="card" style="display:none;">
<h2>Registrarse</h2>

<input id="usuarioRegistro" type="text" placeholder="Nombre de usuario">

<input type="password" placeholder="Contraseña">

<button onclick="crearCuenta()">Crear cuenta</button>
</div>

<div id="perfil" class="card" style="display:none;">
<h2>👋 Bienvenido</h2>

<p>Usuario: <b id="nombreUsuario"></b></p>

<p>🏆 Nivel: Principiante</p>
</div>

<script src="script.js"></script>

</body>
</html>